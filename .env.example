# =========================================================
# Requirement Analyze Agent backend/system environment variables
# Copy this file to .env before starting the backend
# =========================================================

# ---------------------------------------------------------
# LLM provider selection
# Current documented value: openai
# ---------------------------------------------------------
LLM_PROVIDER=openai

# ---------------------------------------------------------
# OpenAI-compatible API configuration
# Works for OpenAI and compatible gateways/proxies
# ---------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o

# ---------------------------------------------------------
# Metadata and secret storage
# If empty, the backend creates and persists a local key file
# ---------------------------------------------------------
REQUIREMENT_ANALYZE_AGENT_METADATA_KEY=

# ---------------------------------------------------------
# LLM call throttling
# Minimum delay between LLM request starts, in seconds
# ---------------------------------------------------------
LLM_MIN_CALL_INTERVAL_SECONDS=0

# Per-request timeout for synchronous LLM calls, in seconds.
# Set to 0 only if you explicitly want to allow unbounded waits.
LLM_REQUEST_TIMEOUT_SECONDS=600

# ---------------------------------------------------------
# Orchestration switches
# ---------------------------------------------------------
USE_DYNAMIC_SUBAGENT=true
USE_MARKDOWN_UPSERT_TOOL=true
ORCHESTRATOR_MAX_PARALLEL=2
ORCHESTRATOR_STALE_TIMEOUT_SECONDS=180

# ---------------------------------------------------------
# Dynamic expert execution limits
# ---------------------------------------------------------
# Total number of ReAct iterations allowed for one expert run.
# Increase for more thorough exploration; decrease to cap runtime/cost.
AGENT_MAX_REACT_STEPS=99

# Max number of batched read-only actions in a single ReAct step.
# Higher values improve parallel evidence collection but reduce focus.
AGENT_MAX_ACTIONS_PER_STEP=2

# Max number of final artifact refinement rounds after core reasoning.
# Increase if outputs often need more polishing before they stabilize.
AGENT_MAX_FINALIZATION_STEPS=16

# Sliding window size used to detect "no progress" in the ReAct loop.
# Smaller values stop earlier; larger values are more tolerant.
AGENT_REACT_PLATEAU_WINDOW=4

# Plateau detection will not trigger before this many steps have run.
# Helps avoid premature stopping on tasks that need initial exploration.
AGENT_REACT_MIN_STEPS_BEFORE_PLATEAU=8

# Repeated missing-path errors allowed before the expert gives up retrying.
# Prevents wasted loops on nonexistent files or directories.
AGENT_PATH_NOT_FOUND_REPEAT_LIMIT=2
