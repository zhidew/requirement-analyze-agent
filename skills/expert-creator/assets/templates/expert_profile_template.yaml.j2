# Expert Profile Template
# Generated by Expert Creator

name: {{ expert_name }}
name_en: {{ expert_name_en | default(expert_name) }}
name_zh: {{ expert_name_zh | default('') }}
capability: {{ expert_id }}
description: "{{ description }}"
version: 0.1.0
skills:
  - {{ expert_id }}
inputs:
  required: {{ required_inputs | default(["requirements", "existing_assets", "output_root"]) }}
  optional: {{ optional_inputs | default(["constraints", "context"]) }}
scheduling:
  priority: {{ priority | default(50) }}
  dependencies: {{ dependencies | default([]) }}
upstream_artifacts: {{ upstream_artifacts | default({}) }}
keywords: {{ keywords | default([]) }}
tools:
  allowed: {{ tools | default(["list_files", "read_file_chunk", "grep_search", "write_file"]) }}
outputs:
  expected: {{ outputs | default(["output.md"]) }}
  evidence: {{ evidence_outputs | default([expert_id + ".json"]) }}
metadata:
  boundary_contract:
    owns: {{ owns | default([expert_id + " domain design artifacts"]) }}
    excludes: {{ excludes | default(["full architecture narrative", "ops runbooks and test inventory"]) }}
    upstream_inputs: {{ upstream_inputs | default(dependencies | default([])) }}
  topic_ownership:
    topics: {{ topic_ownership_topics | default([expert_id.replace("-", "_")]) }}
    owns_shared_context: {{ owns_shared_context | default(false) }}
  routing:
    keywords: {{ routing_keywords | default(keywords | default([])) }}
  prompt_hints:
    file_guidance: {{ file_guidance | default({}) }}
    default_file_guidance: {{ default_file_guidance | default("Use the runtime-provided output plan and evidence to generate only this expert's configured artifacts.") }}
  delivery_contract:
    must_answer: {{ must_answer | default(["What expert-specific decisions and deliverables are required?"]) }}
    evidence_expectations: {{ evidence_expectations | default(["Cite requirement facts and upstream artifacts instead of inventing unsupported details."]) }}
    artifact_review_checklist: {{ artifact_review_checklist | default({}) }}
policies:
  asset_baseline_required: {{ asset_baseline_required | default(true) }}
  evidence_required: {{ evidence_required | default(true) }}
  output_must_be_structured: {{ output_must_be_structured | default(true) }}
  manual_override_forbidden: {{ manual_override_forbidden | default(true) }}
  descriptions_prefer_chinese: {{ descriptions_prefer_chinese | default(true) }}
error_handling:
  on_missing_required_input: {{ on_missing_required_input | default("fail") }}
  on_validation_failure: {{ on_validation_failure | default("fail") }}
  on_partial_generation: {{ on_partial_generation | default("emit_evidence_and_fail") }}
